# Terraform
.terraform/
*.tfstate
*.tfstate.backup
*.tfplan
.terraform.lock.hcl

# Generated Vagrantfiles (build artifacts — source of truth is the .tpl template)
terraform/environments/dev/Vagrantfile
terraform/environments/prod/Vagrantfile

# Vagrant runtime state
.vagrant/
*.box

# Generated Ansible inventories (built by Terraform)
ansible/inventory/*.ini
ansible/inventory/*.yml

# SSH keys — never commit private keys
*.pem
id_rsa
id_ed25519

# IDE
.idea/
*.iml
.vscode/

# macOS
.DS_Store

# Helm chart tarballs — dependencies are fetched at sync time by Argo CD repo-server
gitops/**/charts/*.tgz

# Kubeconfig — generated by Ansible Play 3, contains cluster credentials
ansible/kubeconfig/

# Secrets / env files
*.env
.env.*
secrets/
